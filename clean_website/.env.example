# Copy this file to .env and fill in real values. Never commit the real .env
# (it's already gitignored) -- in production (Render), set these as
# environment variables in the service dashboard instead.

# ---- Database ----
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Auth ----
SESSION_SECRET=replace-with-a-long-random-string

# ---- AI providers ----
GEMINI_API_KEY=
# Comma-separated list of Gemini keys for rotation under rate limits (optional,
# overrides GEMINI_API_KEY if set).
GEMINI_API_KEYS=
GROQ_API_KEY=

# ---- CORS (production only) ----
# Comma-separated list of additional allowed origins beyond *.vercel.app and
# localhost.
CORS_ORIGINS=

# ---- Logging ----
LOG_LEVEL=info

# ---- Billing: Cardcom (Israeli payment gateway) ----
# Pay-as-you-go token purchases, pending Cardcom's account approval. Until
# these are set, POST /api/billing/create-checkout-session runs in stub mode
# and logs what it would have sent instead of calling the real Cardcom API.
CARDCOM_API_KEY=
CARDCOM_TERMINAL_ID=
# Used to verify the signature on incoming POST /api/billing/payment-webhook
# requests once Cardcom provides one. Leave blank in stub mode.
CARDCOM_WEBHOOK_SECRET=
