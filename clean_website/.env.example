# Copy this file to .env and fill in real values. Never commit the real .env
# (it's already gitignored) -- in production (Render), set these as
# environment variables in the service dashboard instead.

# ---- Database ----
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Auth ----
SESSION_SECRET=replace-with-a-long-random-string

# ---- AI providers ----
GEMINI_API_KEY=
# Comma-separated list of Gemini keys for rotation under rate limits (optional,
# overrides GEMINI_API_KEY if set).
GEMINI_API_KEYS=
# Audio transcription (lib/extractor.ts's transcribeAudio, OpenAI's own
# Whisper API -- whisper-1).
OPENAI_API_KEY=

# ---- CORS (production only) ----
# Comma-separated list of additional allowed origins beyond *.vercel.app and
# localhost, e.g. https://focusstudy.net
CORS_ORIGINS=

# ---- Logging ----
LOG_LEVEL=info

# ---- Billing: PayPal (live hosted/NCP checkout, routes/billing.ts) ----
# Token top-up purchases. PAYPAL_ENV=live switches the API base from
# sandbox to production; PAYPAL_CLIENT_ID/SECRET authenticate server-to-server
# calls (order lookup); PAYPAL_WEBHOOK_ID is required to verify that an
# incoming PAYMENT.CAPTURE.COMPLETED webhook genuinely came from PayPal
# before any tokens are credited.
PAYPAL_ENV=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ---- Billing: Zapier/Bit-PayBox (legacy webhook, routes/billing.ts) ----
# Shared secret the Zapier automation sends as X-Zapier-Secret when it
# detects a Bit/PayBox payment notification. Leave unset to keep this
# webhook route rejecting all requests with 404.
ZAPIER_WEBHOOK_SECRET=

# ---- Contact Us form (lib/email.ts, routes/contact.ts) ----
# Brevo API key (https://app.brevo.com/settings/keys/api) used to send
# Contact Us submissions over HTTPS. Leave unset to reject contact-form
# submissions with an error (fails closed -- never silently drops a message).
BREVO_API_KEY=
# Sender address -- must be verified under Brevo's Senders settings. The
# focusstudy.net addresses aren't domain-verified there yet, so this has to
# stay the Gmail address until that's done. Defaults to
# focusstudy.net@gmail.com if unset.
CONTACT_FROM_EMAIL=
# Display name for the sender. Defaults to "FocusStudy" if unset.
CONTACT_FROM_NAME=
# Inbox that receives Contact Us submissions. Defaults to
# focusstudy.net@gmail.com if unset.
CONTACT_TO_EMAIL=
