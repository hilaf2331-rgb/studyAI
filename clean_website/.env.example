# Copy this file to .env and fill in real values. Never commit the real .env
# (it's already gitignored) -- in production (Render), set these as
# environment variables in the service dashboard instead.

# ---- Database ----
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ---- Auth ----
SESSION_SECRET=replace-with-a-long-random-string

# ---- AI providers ----
GEMINI_API_KEY=
# Comma-separated list of Gemini keys for rotation under rate limits (optional,
# overrides GEMINI_API_KEY if set).
GEMINI_API_KEYS=
GROQ_API_KEY=

# ---- CORS (production only) ----
# Comma-separated list of additional allowed origins beyond *.vercel.app and
# localhost.
CORS_ORIGINS=

# ---- Logging ----
LOG_LEVEL=info

# ---- Billing: Cardcom (Israeli payment gateway) ----
# Pay-as-you-go token purchases, pending Cardcom's account approval.
# FocusStudy is currently in a free beta with no payment gateway contract:
# billing.ts's checkout and webhook routes are both fully disabled unless
# BILLING_ENABLED=true, and the webhook additionally requires
# CARDCOM_WEBHOOK_SECRET to be set before it will accept a single request.
# Leave all four unset/false during the beta.
BILLING_ENABLED=false
CARDCOM_API_KEY=
CARDCOM_TERMINAL_ID=
CARDCOM_WEBHOOK_SECRET=

# ---- Contact Us form (lib/email.ts, routes/contact.ts) ----
# A Gmail account + App Password (https://myaccount.google.com/apppasswords)
# used to send Contact Us submissions. Leave unset to silently skip sending
# (the form still returns success, but no email goes out -- logged as a
# warning).
CONTACT_EMAIL_USER=
CONTACT_EMAIL_PASSWORD=
# Defaults to focusstudy.net@gmail.com if unset.
CONTACT_TO_EMAIL=
