{
  "buildCommand": "cd clean_website && pnpm install && pnpm --filter @workspace/study-platform build",
  "outputDirectory": "clean_website/artifacts/study-platform/dist/public",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://studyai-zhyy.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
